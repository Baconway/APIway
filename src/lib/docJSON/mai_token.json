{
  "heading-1": "mai_token API",
  "description": "Used to get an account's token on all.net, to use with websites like maimaiDXNET and chunithmNET",
  "heading-2": "Format",
  "link": "https://apiway.vercel.app/api/mai_token/",
  "methods": [
    {
      "heading-2": "SegaID",
      "method": "POST",
      "link": "https://apiway.vercel.app/api/mai_token/login",
      "heading-3": "JSON Format",
      "description": "Parameters for SegaID login",
      "parameters": [
        {
          "name": "login_mode",
          "value": "sid"
        },
        {
          "name": "sid",
          "description": "SegaID (string)"
        },
        {
          "name": "password",
          "description": "SID password (string)"
        }
      ]
    },
    {
      "heading-2": "Token",
      "method": "GET",
      "link": "https://apiway.vercel.app/api/mai_token/login_bookmark",
      "heading-3": "JSON Format",
      "description": "Parameters for Token login",
      "parameters": [
        {
          "name": "login_mode",
          "value": "token"
        },
        {
          "name": "redirect",
          "description": "where you want the data to end up (url)"
        }
      ]
    }
  ]
}
